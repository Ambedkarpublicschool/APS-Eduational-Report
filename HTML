<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>School Management WebApp</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @media print {
      body * { visibility: hidden; }
      #printArea, #printArea * { visibility: visible; }
      #printArea { position: absolute; left: 0; top: 0; width: 100%; font-size: 14px; }
      .no-print { display: none !important; }
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

  <!-- टॉप नेविगेशन -->
  <header class="bg-white border-b border-slate-200 sticky top-0 z-40 no-print">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <span id="sessionBadge" class="bg-orange-100 text-orange-700 text-sm font-semibold px-3 py-1 rounded-md border border-orange-200">Session: Loading...</span>
      </div>
      <nav class="flex space-x-2">
        <button id="tabBtnAtt" onclick="switchTab('attendance')" class="px-4 py-2 text-sm font-medium rounded-md bg-blue-600 text-white shadow-sm transition">Attendance</button>
        <button id="tabBtnEdu" onclick="switchTab('educational')" class="px-4 py-2 text-sm font-medium rounded-md bg-white text-slate-600 hover:bg-slate-50 border border-slate-200 transition">Educational History</button>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 no-print">
    
    <!-- फ़िल्टर और कंट्रोल सेक्शन -->
    <section class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm mb-6 flex flex-wrap gap-4 items-end">
      <div class="w-full sm:w-auto flex-1 min-w-[200px]" id="dateContainer">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Select Attendance Date</label>
        <input type="date" id="attDate" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
      <div class="w-full sm:w-auto flex-1 min-w-[150px]">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Select Class</label>
        <select id="classSelect" onchange="filterStudents()" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></select>
      </div>
      <div class="w-full sm:w-auto flex-1 min-w-[150px]">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Select Section</label>
        <select id="sectionSelect" onchange="filterStudents()" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></select>
      </div>
      <div class="w-full sm:w-auto flex-1 min-w-[200px] hidden" id="searchContainer">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Search Student</label>
        <input type="text" id="studentSearch" oninput="filterStudents()" placeholder="Name or ID..." class="w-full bg-slate-50 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      </div>
    </section>

    <!-- स्टूडेंट लिस्ट व्यू -->
    <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
      <!-- पीसी (Desktop) टेबल व्यू -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-800 text-white text-xs font-semibold tracking-wider uppercase border-b border-slate-700">
              <th class="px-6 py-4 w-24">Photo</th>
              <th class="px-6 py-4">Student Details</th>
              <th class="px-6 py-4 text-center" id="thAction">Attendance Status</th>
              <th class="px-6 py-4 text-right" id="thSummary">Summary</th>
            </tr>
          </thead>
          <tbody id="studentTableBody" class="divide-y divide-slate-100">
            <!-- डायनामिक डेटा यहाँ आएगा -->
          </tbody>
        </table>
      </div>

      <!-- मोबाइल (Mobile) कार्ड व्यू -->
      <div id="studentCardContainer" class="block md:hidden p-4 space-y-4">
        <!-- डायनामिक कार्ड्स यहाँ आएंगे -->
      </div>
    </section>

    <!-- अटेंडेंस सबमिट बटन -->
    <div class="mt-6 flex justify-end" id="submitAllAttContainer">
      <button onclick="submitAllAttendance()" class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg shadow transition">Submit Attendance</button>
    </div>
  </main>

  <!-- एम्बेड किया गया प्रिंट एरिया जो केवल प्रिंट के वक्त सक्रिय होता है -->
  <div id="printArea" class="hidden p-8 bg-white"></div>

  <!-- मोडल फॉर्म / पॉप-अप: Educational History डेटा इनपुट करने के लिए -->
  <div id="eduModal" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center p-4 z-50 hidden no-print">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh]">
      <div class="bg-slate-800 text-white px-6 py-4 flex items-center justify-between">
        <h3 class="font-bold text-lg" id="modalHeaderTitle">Student Name [ID]</h3>
        <button onclick="closeModal()" class="text-slate-400 hover:text-white text-xl">&times;</button>
      </div>
      <div class="p-6 space-y-4 overflow-y-auto flex-1">
        <input type="hidden" id="modalStudentId">
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Students reaction After teaching(Learning)</label>
          <input type="text" id="eduQ1" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Students reaction After teaching(Writing)</label>
          <input type="text" id="eduQ2" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Presence, cleanness(total)</label>
          <input type="text" id="eduQ3" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Study Material Availbity</label>
          <input type="text" id="eduQ4" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase mb-1">Reaction of Paret atfer knowing all about Student</label>
          <textarea id="eduQ5" rows="3" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
        </div>
      </div>
      <div class="bg-slate-50 px-6 py-4 flex justify-end space-x-2 border-t border-slate-100">
        <button onclick="closeModal()" class="px-4 py-2 text-sm font-medium border border-slate-200 rounded-lg bg-white text-slate-600 hover:bg-slate-50">Cancel</button>
        <button onclick="saveEducationalHistory()" class="px-4 py-2 text-sm font-medium rounded-lg bg-blue-600 text-white hover:bg-blue-700 shadow-sm">Submit</button>
      </div>
    </div>
  </div>

  <!-- मुख्य जावास्क्रिप्ट लॉजिक -->
  <script>
    // ⚠️ महत्वपूर्ण: नीचे दिए गए URL को अपने खुद के Apps Script Web App Deployment URL से बदलें
    const API_URL = "https://script.google.com/macros/s/AKfycbwTKDKnw0ZqDhctt7a_w3QpaH5uYgVjZVka_sTfi2HuY17jJFLdLfpF7hyt5gvYkEPZig/exec";

    let currentTab = 'attendance';
    let globalData = { session: "", classes: [], sections: [], students: [] };

    // डिफ़ॉल्ट रूप से आज की तारीख को फ़ील्ड में सेट करना (Format: DD-MMM)
    document.addEventListener("DOMContentLoaded", () => {
      const today = new Date();
      document.getElementById('attDate').value = today.toISOString().split('T')[0];
      loadInitialData();
    });

    // बैकएंड से इनिशियल मास्टर डेटा लोड करना
    function loadInitialData() {
      fetch(`${API_URL}?action=getInitialData`)
        .then(res => res.json())
        .then(data => {
          globalData = data;
          document.getElementById("sessionBadge").innerText = `Session: ${data.session}`;
          
          populateDropdown("classSelect", data.classes);
          populateDropdown("sectionSelect", data.sections);
          
          filterStudents();
        })
        .catch(err => alert("डेटा लोड करने में त्रुटि: " + err));
    }

    function populateDropdown(id, items) {
      const select = document.getElementById(id);
      select.innerHTML = items.map(item => `<option value="${item}">${item}</option>`).join('');
    }

    // मॉड्यूल टैब स्विचिंग लॉजिक
    function switchTab(tab) {
      currentTab = tab;
      const btnAtt = document.getElementById("tabBtnAtt");
      const btnEdu = document.getElementById("tabBtnEdu");
      const dateCont = document.getElementById("dateContainer");
      const searchCont = document.getElementById("searchContainer");
      const thAction = document.getElementById("thAction");
      const thSummary = document.getElementById("thSummary");
      const submitAllCont = document.getElementById("submitAllAttContainer");

      if (tab === 'attendance') {
        btnAtt.className = "px-4 py-2 text-sm font-medium rounded-md bg-blue-600 text-white shadow-sm transition";
        btnEdu.className = "px-4 py-2 text-sm font-medium rounded-md bg-white text-slate-600 hover:bg-slate-50 border border-slate-200 transition";
        dateCont.classList.remove("hidden");
        searchCont.classList.add("hidden");
        thAction.innerText = "Attendance Status";
        thSummary.classList.remove("hidden");
        submitAllCont.classList.remove("hidden");
      } else {
        btnEdu.className = "px-4 py-2 text-sm font-medium rounded-md bg-blue-600 text-white shadow-sm transition";
        btnAtt.className = "px-4 py-2 text-sm font-medium rounded-md bg-white text-slate-600 hover:bg-slate-50 border border-slate-200 transition";
        dateCont.classList.add("hidden");
        searchCont.classList.remove("hidden");
        thAction.innerText = "Actions";
        thSummary.classList.add("hidden");
        submitAllCont.classList.add("hidden");
      }
      filterStudents();
    }

    // फ़िल्टर और सर्च के आधार पर UI लिस्ट रेंडर करना
    function filterStudents() {
      const selClass = document.getElementById("classSelect").value;
      const selSection = document.getElementById("sectionSelect").value;
      const searchVal = document.getElementById("studentSearch").value.toLowerCase();
      
      const filtered = globalData.students.filter(st => {
        const matchesClass = st.className.toString() === selClass;
        const matchesSection = st.section.toString() === selSection;
        const matchesSearch = currentTab === 'educational' ? (st.name.toLowerCase().includes(searchVal) || st.id.toString().toLowerCase().includes(searchVal)) : true;
        return matchesClass && matchesSection && matchesSearch;
      });

      renderDesktopTable(filtered);
      renderMobileCards(filtered);
    }

    // पीसी लेआउट रेंडरर
    function renderDesktopTable(students) {
      const tbody = document.getElementById("studentTableBody");
      if (students.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="text-center p-6 text-slate-400 text-sm">कोई छात्र सक्रिय नहीं मिला।</td></tr>`;
        return;
      }

      tbody.innerHTML = students.map(st => {
        let actionHtml = "";
        let summaryHtml = "";

        if (currentTab === 'attendance') {
          actionHtml = `
            <div class="flex items-center justify-center space-x-3">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="att_${st.id}" class="sr-only peer" checked>
                <div class="w-11 h-6 bg-red-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                <span class="ml-2 text-sm font-medium text-slate-600 select-none peer-checked:text-emerald-600 transition" id="lbl_${st.id}">Present</span>
              </label>
            </div>`;
          summaryHtml = `
            <div class="flex items-center justify-end space-x-2 text-xs font-semibold">
              <span class="bg-teal-50 text-teal-700 border border-teal-200 px-2 py-1 rounded">Total P: ${st.totalP}</span>
              <span class="bg-blue-50 text-blue-700 border border-blue-200 px-2 py-1 rounded">Month P: ${st.monthP}</span>
            </div>`;
        } else {
          actionHtml = `
            <div class="flex items-center justify-center space-x-2">
              <button onclick="viewReport('${st.id}', '${st.name}')" class="bg-slate-100 hover:bg-slate-200 border border-slate-300 text-slate-700 px-3 py-1.5 rounded-lg text-xs font-medium transition shadow-sm">View Report</button>
              <button onclick="openSubmitModal('${st.id}', '${st.name}')" class="bg-blue-50 text-blue-600 hover:bg-blue-100 border border-blue-200 px-3 py-1.5 rounded-lg text-xs font-medium transition shadow-sm">Submit Report</button>
            </div>`;
        }

        const photoUrl = st.photo || "https://via.placeholder.com/150";

        return `
          <tr class="hover:bg-slate-50/70 transition">
            <td class="px-6 py-4"><img src="${photoUrl}" class="w-10 h-10 rounded-full object-cover border border-slate-200 shadow-sm mx-auto"></td>
            <td class="px-6 py-4">
              <div class="font-bold text-slate-900">${st.name}</div>
              <div class="text-xs text-slate-400 flex space-x-2 mt-0.5"><span>ID: ${st.id}</span></div>
            </td>
            <td class="px-6 py-4">${actionHtml}</td>
            <td class="px-6 py-4 text-right">${summaryHtml}</td>
          </tr>
        `;
      }).join('');

      // हाजिरी वाले टॉगल बटन के टेक्स्ट को डायनामिक बदलना (Present/Absent)
      if (currentTab === 'attendance') {
        students.forEach(st => {
          const chk = document.getElementById(`att_${st.id}`);
          if(chk) {
            chk.addEventListener('change', (e) => {
              document.getElementById(`lbl_${st.id}`).innerText = e.target.checked ? "Present" : "Absent";
              document.getElementById(`lbl_${st.id}`).className = e.target.checked ? "ml-2 text-sm font-medium text-emerald-600 select-none" : "ml-2 text-sm font-medium text-red-600 select-none";
            });
          }
        });
      }
    }

    // मोबाइल कार्ड लेआउट रेंडरर
    function renderMobileCards(students) {
      const container = document.getElementById("studentCardContainer");
      if (students.length === 0) {
        container.innerHTML = `<div class="text-center py-6 text-slate-400 text-sm">कोई छात्र सक्रिय नहीं मिला।</div>`;
        return;
      }

      container.innerHTML = students.map(st => {
        const photoUrl = st.photo || "https://via.placeholder.com/150";
        let actionSection = "";

        if (currentTab === 'attendance') {
          actionSection = `
            <div class="flex items-center justify-between border-t border-slate-100 pt-3 mt-3">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="m_att_${st.id}" class="sr-only peer" checked>
                <div class="w-11 h-6 bg-red-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-emerald-500"></div>
                <span class="ml-2 text-sm font-medium text-emerald-600 select-none" id="m_lbl_${st.id}">Present</span>
              </label>
              <div class="flex space-x-1 text-[11px] font-semibold">
                <span class="bg-teal-50 text-teal-600 px-2 py-0.5 rounded border border-teal-100">Total P: ${st.totalP}</span>
                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded border border-blue-100">Month P: ${st.monthP}</span>
              </div>
            </div>`;
        } else {
          actionSection = `
            <div class="grid grid-cols-2 gap-2 border-t border-slate-100 pt-3 mt-3">
              <button onclick="viewReport('${st.id}', '${st.name}')" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 py-2 rounded-lg text-xs font-semibold text-center border border-slate-200 transition">View Report</button>
              <button onclick="openSubmitModal('${st.id}', '${st.name}')" class="w-full bg-blue-50 text-blue-600 hover:bg-blue-100 py-2 rounded-lg text-xs font-semibold text-center border border-blue-200 transition">Submit Report</button>
            </div>`;
        }

        return `
          <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-center space-x-3">
              <img src="${photoUrl}" class="w-12 h-12 rounded-full object-cover border border-slate-200">
              <div>
                <h4 class="font-bold text-slate-900">${st.name}</h4>
                <p class="text-xs text-slate-400">ID: ${st.id}</p>
              </div>
            </div>
            ${actionSection}
          </div>
        `;
      }).join('');

      if (currentTab === 'attendance') {
        students.forEach(st => {
          const mChk = document.getElementById(`m_att_${st.id}`);
          if(mChk) {
            mChk.addEventListener('change', (e) => {
              document.getElementById(`m_lbl_${st.id}`).innerText = e.target.checked ? "Present" : "Absent";
              document.getElementById(`m_lbl_${st.id}).className = e.target.checked ? "ml-2 text-sm font-medium text-emerald-600" : "ml-2 text-sm font-medium text-red-600";
            });
          }
        });
      }
    }

    // अटेंडेंस सबमिट करने की प्रक्रिया
    function submitAllAttendance() {
      const selClass = document.getElementById("classSelect").value;
      const selSection = document.getElementById("sectionSelect").value;
      
      const filtered = globalData.students.filter(st => st.className.toString() === selClass && st.section.toString() === selSection);
      if(filtered.length === 0) return alert("सबमिट करने के लिए कोई छात्र मौजूद नहीं है।");

      const rawDate = document.getElementById('attDate').value; // YYYY-MM-DD
      if(!rawDate) return alert("कृपया सही तारीख चुनें!");
      
      // तारीख को शीट हेडर फॉर्मेट में बदलना (जैसे 17-07-2026 से 17-Jul बनाना)
      const dateObj = new Date(rawDate);
      const day = dateObj.getDate();
      const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
      const formattedDate = `${day}-${monthNames[dateObj.getMonth()]}`;

      const records = filtered.map(st => {
        let isPresent = true;
        if (window.innerWidth >= 768) {
          isPresent = document.getElementById(`att_${st.id}`) ? document.getElementById(`att_${st.id}`).checked : true;
        } else {
          isPresent = document.getElementById(`m_att_${st.id}`) ? document.getElementById(`m_att_${st.id}`).checked : true;
        }
        return { studentId: st.id, status: isPresent ? "P" : "A" };
      });

      const payload = { action: "submitAttendance", date: formattedDate, records: records };

      fetch(API_URL, {
        method: "POST",
        body: JSON.stringify(payload)
      })
      .then(res => res.json())
      .then(res => {
        if(res.status === "success") {
          alert("हाजिरी सफलतापूर्वक दर्ज हो गई है!");
          loadInitialData(); // लाइव री-फ्रेश काउंटर्स देखने के लिए
        } else {
          alert("त्रुटि: " + res.message);
        }
      })
      .catch(err => alert("सबमिशन फेल: " + err));
    }

    // एजुकेशनल हिस्ट्री मोडल कंट्रोल्स
    function openSubmitModal(id, name) {
      document.getElementById("modalStudentId").value = id;
      document.getElementById("modalHeaderTitle").innerText = `${name} [ID: ${id}]`;
      
      // पुराने इनपुट रिसेट करना
      document.getElementById("eduQ1").value = "";
      document.getElementById("eduQ2").value = "";
      document.getElementById("eduQ3").value = "";
      document.getElementById("eduQ4").value = "";
      document.getElementById("eduQ5").value = "";

      document.getElementById("eduModal").classList.remove("hidden");
    }

    function closeModal() {
      document.getElementById("eduModal").classList.add("hidden");
    }

    // एजुकेशनल हिस्ट्री रिपोर्ट सेल में अपेंड (Append) करना
    function saveEducationalHistory() {
      const id = document.getElementById("modalStudentId").value;
      const answers = {
        "Students reaction After teaching(Learning)": document.getElementById("eduQ1").value,
        "Students reaction After teaching(Writing)": document.getElementById("eduQ2").value,
        "Presence, cleanness(total)": document.getElementById("eduQ3").value,
        "Study Material Availbity": document.getElementById("eduQ4").value,
        "Reaction of Paret atfer knowing all about  Student": document.getElementById("eduQ5").value
      };

      const payload = { action: "submitEducationalHistory", studentId: id, answers: answers };

      fetch(API_URL, {
        method: "POST",
        body: JSON.stringify(payload)
      })
      .then(res => res.json())
      .then(res => {
        if(res.status === "success") {
          alert("शैक्षणिक इतिहास सफलतापूर्वक सेल में अपेंड हो गया है!");
          closeModal();
        }
      })
      .catch(err => alert("त्रुटि: " + err));
    }

    // व्यू रिपोर्ट और A4 प्रिंट जेनरेशन
    function viewReport(id, name) {
      fetch(`${API_URL}?action=getEducationalHistory&studentId=${id}`)
        .then(res => res.json())
        .then(data => {
          const report = data.report;
          const printArea = document.getElementById("printArea");
          
          if (!report) {
            alert("इस छात्र का कोई पुराना इतिहास नहीं मिला।");
            return;
          }

          const fields = [
            "Students reaction After teaching(Learning)",
            "Students reaction After teaching(Writing)",
            "Presence, cleanness(total)",
            "Study Material Availbity",
            "Reaction of Paret atfer knowing all about  Student"
          ];

          let historyTimelineHtml = "";
          
          // सेल के अंदर '\n' द्वारा विभक्त डेटा को कस्टमाइज़्ड टाइमलाइन रो बनाना
          fields.forEach(field => {
            if(report[field]) {
              const logs = report[field].split("\n");
              let logItems = logs.map(l => `<div class="bg-slate-50 border border-slate-100 p-2.5 rounded-lg text-xs font-mono text-slate-700 mb-1.5 shadow-sm">${l}</div>`).join('');
              
              historyTimelineHtml += `
                <div class="border border-slate-200 rounded-xl p-4 bg-white shadow-sm">
                  <h4 class="text-sm font-bold text-slate-800 mb-2 border-b border-slate-100 pb-1 uppercase tracking-wide">${field}</h4>
                  <div>${logItems}</div>
                </div>`;
            }
          });

          // A4 प्रिंट फ्रेंडली HTML लेआउट तैयार करना
          printArea.innerHTML = `
            <div class="max-w-4xl mx-auto bg-white p-6">
              <div class="flex justify-between items-center border-b-2 border-slate-800 pb-4 mb-6">
                <div>
                  <h1 class="text-2xl font-black text-slate-900 tracking-tight">Ambedkar Public School</h1>
                  <p class="text-xs text-slate-500 font-medium">Madhopur, Campierganj - Gorakhpur</p>
                </div>
                <div class="text-right">
                  <h2 class="text-lg font-bold text-slate-700">STUDENT REPORT CARD</h2>
                  <p class="text-xs bg-slate-100 text-slate-800 px-2 py-0.5 rounded font-semibold mt-1 inline-block">Session: ${globalData.session}</p>
                </div>
              </div>
              
              <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl flex items-center space-x-4 mb-6">
                <img src="${report["Student Photo Link (Drive)"] || 'https://via.placeholder.com/150'}" class="w-16 h-16 rounded-full object-cover border-2 border-white shadow-sm">
                <div class="grid grid-cols-2 gap-x-6 gap-y-1 text-sm">
                  <div><span class="text-slate-400 font-medium">Student Name:</span> <strong class="text-slate-800">${name}</strong></div>
                  <div><span class="text-slate-400 font-medium">Student ID:</span> <strong class="text-slate-800">${id}</strong></div>
                  <div><span class="text-slate-400 font-medium">Class:</span> <strong class="text-slate-800">${report["Current Class"]}</strong></div>
                  <div><span class="text-slate-400 font-medium">Section:</span> <strong class="text-slate-800">${report["Section"]}</strong></div>
                </div>
              </div>

              <div class="space-y-4">
                <h3 class="text-base font-bold text-slate-900 border-l-4 border-blue-600 pl-2">Educational History Log</h3>
                ${historyTimelineHtml || '<p class="text-sm text-slate-400">कोई डेटा उपलब्ध नहीं है।</p>'}
              </div>

              <div class="mt-12 pt-8 border-t border-dashed border-slate-300 flex justify-between text-xs font-semibold text-slate-400 uppercase tracking-wider no-print">
                <button onclick="window.print()" class="bg-blue-600 text-white px-5 py-2.5 rounded-lg font-bold shadow hover:bg-blue-700 transition">Print A4 Report</button>
                <button onclick="closeReport()" class="bg-slate-200 text-slate-700 px-5 py-2.5 rounded-lg font-bold hover:bg-slate-300 transition">Close Report</button>
              </div>
            </div>`;

          // UI स्विच करके केवल प्रिंट एरिया दिखाना
          document.querySelector('header').classList.add('hidden');
          document.querySelector('main').classList.add('hidden');
          printArea.classList.remove('hidden');
        })
        .catch(err => alert("इतिहास प्राप्त करने में विफलता: " + err));
    }

    function closeReport() {
      document.getElementById("printArea").classList.add('hidden');
      document.querySelector('header').classList.remove('hidden');
      document.querySelector('main').classList.remove('hidden');
    }
  </script>
</body>
</html>
